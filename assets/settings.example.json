// Asylum settings — JSON with comments. Every key is optional: a missing or
// removed key falls back to its built-in default. Edits apply live (the file
// is watched), and the in-app Settings surface (cmd-,) writes back here
// without touching your comments.
{
    // Chrome theme: "dark" or "light".
    "theme": "dark",

    // Where per-task worktrees are created, relative to a project root.
    "worktree_dir": ".asylum/worktrees",

    // Agents fanned out by default when a task is dispatched. Ids come from the
    // built-in registry (for example: claude-code, opencode, gemini, aider).
    "default_agents": ["claude-code", "codex"],

    // Cap on concurrent agent runs across all tasks (0 = unlimited), and stop
    // runs that exceed the timeout in minutes (0 = no timeout).
    "max_parallel_runs": 4,
    "run_timeout_minutes": 60,

    // Per-agent overrides.
    "agents": {
        "codex": { "extra_args": ["--model", "o1"] },
        "aider": { "enabled": false }
    },

    // Built-in editor.
    "editor": {
        "font_family": "monospace",
        "font_size": 13,
        "tab_width": 4,
        "autosave": true
    },

    // Keybindings layered over the defaults, as "chord=action" strings in gpui
    // keystroke syntax; "chord=" (empty action) unbinds a default.
    //   e.g. ["cmd-shift-p=command_palette", "cmd-enter="]
    // Actions: command_palette, quick_open, find_in_project, new_task,
    // open_project, run_fanout, review_diff, new_terminal, split_right,
    // close_tab, settings, open_settings_file, toggle_theme, switch_account,
    // notifications, quit, tasks, search, integrations, terminal, editor,
    // browser, preview, plugins.
    "keybindings": []
}
