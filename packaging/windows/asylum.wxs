<?xml version="1.0" encoding="utf-8"?>
<!--
  Asylum MSI (WiX v4). Installs asylum.exe and the license/readme into Program
  Files, with a Start-menu shortcut. Files come from the staging tree the build
  script assembles (StageDir); the version is injected from the workspace
  Cargo.toml. Both are passed with `wix build -define`. Unsigned for now —
  installers show a SmartScreen "unknown publisher" prompt until an Authenticode
  certificate is wired in.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="Asylum"
      Manufacturer="Wess Cope"
      Version="$(Version)"
      UpgradeCode="4EA046C2-0907-459F-BC08-686C42839128"
      Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Asylum is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Asylum" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutDir" Name="Asylum" />
    </StandardDirectory>

    <ComponentGroup Id="AppFiles">
      <Component Directory="INSTALLFOLDER">
        <File Id="AsylumExe" Source="$(StageDir)\asylum.exe" KeyPath="yes" />
      </Component>
      <Component Directory="INSTALLFOLDER">
        <File Source="$(StageDir)\LICENSE" />
      </Component>
      <Component Directory="INSTALLFOLDER">
        <File Source="$(StageDir)\README.md" />
      </Component>
    </ComponentGroup>

    <!-- Start-menu shortcut to the app. -->
    <Component Id="AppShortcut" Directory="AppShortcutDir">
      <Shortcut Id="AsylumStartMenu"
                Name="Asylum"
                Target="[INSTALLFOLDER]asylum.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppShortcutDir" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Asylum" Name="installed"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="Asylum" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AppShortcut" />
    </Feature>
  </Package>
</Wix>
